{
  "manifest_version": 3,
  "name": "Lucy Bridge",
  "version": "0.1",
  "description": "Connect Chrome to Lucy AI Desktop Agent",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Send page to Lucy",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}

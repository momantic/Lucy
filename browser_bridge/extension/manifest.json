{
  "manifest_version": 3,
  "name": "Lucy Browser Bridge",
  "version": "0.1.0",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8765/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
